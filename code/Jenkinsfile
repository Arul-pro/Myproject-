pipeline {
    agent any
    
    environment {
        IMAGE_NAME   = "arulgun/mddevopsmasterclass:${GIT_COMMIT}"
        EKS_ENDPOINT = "https://726C0A19F2162CE71D70AFE61DAFBD1B.gr7.ap-southeast-2.eks.amazonaws.com"
        CLUSTER_NAME = "app"
        NAMESPACE    = "microdegree"
    } 

    stages {
        stage('Git-Checkout') {
            steps {
                git url: 'https://github.com/Arul-pro/Myproject-.git', branch: 'main'
            }
        }

        stage('Build') {
            steps {
                sh '''
                    printenv
                    pwd
                    cd code/
                    docker build -t ${IMAGE_NAME} .
                '''
            }
        }

        stage('Docker Hub Login') {
            steps {
                withCredentials([usernamePassword(credentialsId: 'docker-hub-creds', passwordVariable: 'DOCKER_PASSWORD', usernameVariable: 'DOCKER_USERNAME')]) {
                    sh 'echo "$DOCKER_PASSWORD" | docker login -u "$DOCKER_USERNAME" --password-stdin'
                }
            }
        }

        stage('Pushing to Registry') {
            steps {
                sh 'docker push ${IMAGE_NAME}'
            }
        }

        stage('Deploy to EKS Cluster') {
            steps {
                // Native Jenkins Kubernetes wrapping block
                withKubeConfig(
                    caCertificate: '', 
                    clusterName: "${CLUSTER_NAME}", 
                    contextName: '', 
                    credentialsId: 'kube', 
                    namespace: "${NAMESPACE}", 
                    restrictKubeConfigAccess: false, 
                    serverUrl: "${EKS_ENDPOINT}"
                ) {
                    sh '''
                        cd code/
                        if [ -f deployment.yaml ]; then
                            echo "Updating manifest with target image tag: ${IMAGE_NAME}"
                            
                            # Update the image tag directly in the deployment file
                            sed -i "s|image:.*|image: ${IMAGE_NAME}|g" deployment.yaml
                            
                            # Apply the changes safely using the secure context active inside this block
                            kubectl apply -f deployment.yaml
                        else
                            echo "ERROR: deployment.yaml file missing under code/ directory."
                            exit 1
                        fi
                    '''
                }
            }
        }
    }

    post {
        always {
            // Clean up the local agent docker cache to save disk space
            sh 'docker rmi ${IMAGE_NAME} || true'
        }
    }
}
